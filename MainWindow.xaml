<Window x:Class="WindowsSpotlightWallpaperTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowsSpotlightWallpaperTool"
        Title="Windows Spotlight Wallpaper Tool"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#D7DCE2"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Windows 聚焦壁纸" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#6B7280"
                               Text="{Binding ScanSummary}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Text="比例" />
                    <ComboBox Width="112"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding AspectFilters}"
                              SelectedItem="{Binding SelectedAspectFilter}"
                              SelectionChanged="AspectFilterComboBox_SelectionChanged" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Text="另存格式" />
                    <ComboBox Width="82"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding ExportFormats}"
                              SelectedItem="{Binding SelectedExportFormat}" />
                    <Button Content="重新扫描"
                            Click="RefreshButton_Click" />
                    <Button Content="另存勾选图片"
                            Click="SaveSelectedButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#D7DCE2"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="12"
                               FontWeight="SemiBold"
                               Text="{Binding ImageCountText}" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Images}"
                             SelectedItem="{Binding SelectedImage}"
                             SelectionChanged="ImagesListBox_SelectionChanged"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:SpotlightImage}">
                                <Border Width="190"
                                        Margin="8"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="6">
                                    <StackPanel>
                                        <Grid>
                                            <Image Height="105"
                                                   Stretch="UniformToFill"
                                                   Source="{Binding Thumbnail}" />
                                            <CheckBox HorizontalAlignment="Left"
                                                      VerticalAlignment="Top"
                                                      Margin="6"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Checked="ImageCheckBox_Changed"
                                                      Unchecked="ImageCheckBox_Changed" />
                                        </Grid>
                                        <TextBlock Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding SourceLabel}" />
                                        <TextBlock Foreground="#4B5563"
                                                   Text="{Binding Dimensions}" />
                                        <TextBlock Foreground="#6B7280"
                                                   Text="{Binding FileSize}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#EEF2F7" />

            <Border Grid.Column="2"
                    BorderBrush="#D7DCE2"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform" />
                            <CheckBox HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Margin="12"
                                      IsChecked="{Binding SelectedImage.IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Checked="ImageCheckBox_Changed"
                                      Unchecked="ImageCheckBox_Changed" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="0,12,0,0">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding SelectedImage.SourceLabel}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding SelectedImage.FileName}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#4B5563"
                                   Text="{Binding SelectedImage.Dimensions}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2"
                   Margin="0,12,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="#6B7280"
                           Text="{Binding ProjectInfo}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
